model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  isAdmin      Boolean? @default(false) @map("is_admin")
  isAuthorized Boolean? @default(false) @map("is_authorized")

  profile      Profile?
  token        Token?
  userJobs     UserJob[]
  userJobScore UserJobScore[]

  @@map("users")
}
