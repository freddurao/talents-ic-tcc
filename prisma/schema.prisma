generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    COMMON
    ADMIN

    @@map("user_role")
}

enum CompanyRequestStatus {
    PENDING
    APPROVED
    REJECTED

    @@map("company_request_status")
}

model User {
    id        String   @id @default(uuid())
    name      String   @db.VarChar(120)
    email     String   @unique @db.VarChar(255)
    password  String
    role      UserRole @default(COMMON)
    isActive  Boolean  @default(true) @map("is_active")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    profile         Profile?
    token           Token?
    companyId       String?          @map("company_id")
    company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
    companyRequests CompanyRequest[]
    userJobs        UserJob[]
    userJobScores   UserJobScore[]

    @@map("users")
}

model Token {
    id         String   @id @default(uuid())
    token      String   @unique
    expiration DateTime

    userId String @unique @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("tokens")
}

model Profile {
    id           String    @id @default(uuid())
    searchable   Boolean   @default(true) // Visível para recomendação de recrutadores
    birthDate    DateTime? @map("birth_date") @db.Date
    scholarity   String?   @db.VarChar(30) // Texto livre para o TF-IDF
    knowledge    String?   @db.Text // Conhecimentos gerais (separados por ";")
    technologies String?   @db.Text // Stack técnica (separada por ";")
    languages    String?   @db.VarChar(255) // Idiomas (separados por ";")
    linkResume   String?   @map("link_resume") @db.VarChar(255)
    createdAt    DateTime  @default(now()) @map("created_at")
    updatedAt    DateTime  @updatedAt @map("updated_at")

    userId String @unique @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("user_profiles")
}

model Company {
    id          String   @id @default(uuid())
    name        String   @db.VarChar(150)
    cnpj        String   @unique @db.VarChar(18)
    description String?  @db.Text
    website     String?  @db.VarChar(255)
    segment     String?  @db.VarChar(100)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    companyRequests CompanyRequest[]
    jobs            Job[]
    users           User[]

    @@map("companies")
}

model CompanyRequest {
    id         String                  @id @default(uuid())
    status     CompanyRequestStatus @default(PENDING)
    createdAt  DateTime             @default(now()) @map("created_at")
    reviewedAt DateTime?            @map("reviewed_at")

    userId String  @map("user_id")
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    companyId String?     @map("company_id")
    company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

    @@map("company_requests")
}

model Job {
    id           String       @id @default(uuid())
    title        String    @db.VarChar(120)
    description  String    @db.Text
    scholarity   String?   @db.VarChar(30) // Texto livre para o TF-IDF
    type         String?   @db.VarChar(30) // CLT, PJ, Freelancer, etc.
    site         String?   @db.VarChar(255) // Link do portal externo (Gupy, etc.)
    contactEmail String?   @map("contact_email") @db.VarChar(255) // E-mail do recrutador
    workload     Float? // Carga horária semanal
    salary       Float?
    startingDate DateTime? @map("starting_date") @db.Date
    endingDate   DateTime? @map("ending_date") @db.Date
    createdAt    DateTime  @default(now()) @map("created_at")
    updatedAt    DateTime  @updatedAt @map("updated_at")

    // Empresa opcional — a maioria das vagas não terá
    companyId String?     @map("company_id")
    company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

    userJobs      UserJob[]
    userJobScores UserJobScore[]

    @@map("jobs")
}

model Skill {
    id   String    @id @default(uuid())
    name String @unique @db.VarChar(100)

    @@map("skills")
}

model Technology {
    id   String    @id @default(uuid())
    name String @unique @db.VarChar(100)

    @@map("technologies")
}

model Language {
    id   String    @id @default(uuid())
    name String @unique @db.VarChar(80)

    @@map("languages")
}

model UserJob {
    created Boolean // true = criou | false = se candidatou

    userId String  @map("user_id")
    jobId  String  @map("job_id")
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
    job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@id([userId, jobId])
    @@map("user_jobs")
}

model UserJobScore {
    id     String    @id @default(uuid())
    status String @default("none") // "none" | "like" | "dislike"

    userId String  @map("user_id")
    jobId  String  @map("job_id")
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
    job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@unique([userId, jobId])
    @@map("user_job_scores")
}
