generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  isAdmin      Boolean? @default(false)
  isAuthorized Boolean? @default(false)

  profile      Profile?
  token        Token?
  userJobs     UserJob[]
  userJobScore UserJobScore[]

  @@map("users")
}

model Profile {
  id           Int      @id @default(autoincrement())
  birthDate    DateTime  //@db.Date
  scholarity   String   //@db.VarChar(30)
  knowledge    String   //@db.Text
  technologies String   //@db.Text
  languages    String?  //@db.VarChar(255)
  linkResume   String?  //@db.VarChar(255)
  searchable   Boolean

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Job {
  id           Int      @id @default(autoincrement())
  description  String   //@db.Text
  scholarity   String   //@db.VarChar(30)
  title        String   //@db.VarChar(60)
  type         String   //@db.VarChar(12)
  site         String   //@db.VarChar(30)
  workload     Float
  salary       Float
  startingDate DateTime //@db.Date
  endingDate   DateTime //@db.Date
  createdAt    DateTime //@default(now()) @db.Date

  userJobs     UserJob[]
  userJobScore UserJobScore[]

  @@map("jobs")
}

model Skill {
  id          Int    @id @default(autoincrement())
  description String //@db.VarChar(60)

  @@map("skills")
}

model Technology {
  id          Int    @id @default(autoincrement())
  description String //@db.VarChar(60)

  @@map("technologies")
}

model UserJob {
  created Boolean

  userId Int
  jobId  Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([userId, jobId])
  @@map("user_jobs")
}

model UserJobScore {
  id     Int    @id @default(autoincrement())
  status String

  userId Int
  jobId  Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("user_job_scores")
}

model EmailList {
  id       Int      @id @default(autoincrement())
  email    String
  isActive Boolean? @default(false)

  @@map("email_lists")
}

model Token {
  id         Int      @id @default(autoincrement())
  expiration DateTime
  token      String   @unique

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}